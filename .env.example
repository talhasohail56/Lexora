# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=3&pool_timeout=20"

# JWT secret (use a long random string in production)
JWT_SECRET="lexora-dev-secret-change-me-in-production-please"
SESSION_MAX_AGE_DAYS="90"
WARMUP_SECRET=""

# OpenAI (optional — without it, deterministic mock responses are used)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBED_MODEL="text-embedding-3-small"

# App
NEXT_PUBLIC_APP_NAME="Lexora"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend OTP email
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Lexora <onboarding@resend.dev>"
RESEND_REPLY_TO_EMAIL="lexoraaiparalegal@gmail.com"
LEXORA_SUPPORT_EMAIL="lexoraaiparalegal@gmail.com"

# Gmail SMTP OTP email. If GMAIL_APP_PASSWORD is set, Gmail is used before Resend.
EMAIL_FROM_NAME="Lexora"
GMAIL_USER="lexoraaiparalegal@gmail.com"
GMAIL_APP_PASSWORD=""

# Google OAuth
# Client ID ends with .apps.googleusercontent.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
